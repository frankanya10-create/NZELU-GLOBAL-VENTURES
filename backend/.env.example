# Backend Environment Variables
# Copy this file to .env and fill in the values

MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/ngv_erp?retryWrites=true&w=majority
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRY=8h
OTP_SECRET=your_otp_encryption_salt
PORT=5000
NODE_ENV=production
INACTIVITY_TIMEOUT=900000
FRONTEND_URL=https://your-vercel-deployment.vercel.app

# Gmail SMTP (optional - for staff credential emails)
# EMAIL_USER=your.email@gmail.com
# EMAIL_PASS=your-gmail-app-password
